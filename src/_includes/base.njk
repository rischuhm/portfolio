<!DOCTYPE html>
{%- set isEn = page.url.startsWith('/en/') -%}
{%- set lang = 'en' if isEn else 'de' -%}
{%- set rootUrl = '/en/' | url if isEn else '/' | url -%}
{%- set projectsUrl = '/en/projects/' | url if isEn else '/projects/' | url -%}
{%- set impressumUrl = '/en/impressum/' | url if isEn else '/impressum/' | url -%}
{%- set datenschutzUrl = '/en/datenschutz/' | url if isEn else '/datenschutz/' | url -%}
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>{% if title %}{{ title }} — {{ cv.name }}{% else %}{{ cv.name }} — {{ cv.title }}{% endif %}</title>
  <meta name="description" content="{{ cv.summary }}">
  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="{{ '/styles/bootstrap-icons/bootstrap-icons.css' | url }}">
  <link rel="stylesheet" href="{{ '/styles/main.css' | url }}">
</head>
<body>
  {%- set navPrefix = "" if page.url == rootUrl else rootUrl -%}
  {%- if isEn -%}
    {%- set deUrl = '/' | url if page.url == '/en/' else page.url | replace('/en/', '/') | url -%}
    {%- set enUrl = page.url | url -%}
  {%- else -%}
    {%- set deUrl = page.url | url -%}
    {%- set enUrl = ('/en' + page.url) | url -%}
  {%- endif -%}
  <nav class="globalnav" aria-label="Global">
    <div class="globalnav__lang" aria-label="{% if isEn %}Language switcher{% else %}Sprachumschalter{% endif %}">
      <a class="globalnav__lang-link{% if not isEn %} globalnav__lang-link--active{% endif %}" href="{{ deUrl }}">DE</a>
      <span class="globalnav__lang-sep" aria-hidden="true">|</span>
      <a class="globalnav__lang-link{% if isEn %} globalnav__lang-link--active{% endif %}" href="{{ enUrl }}">EN</a>
    </div>
    <div class="globalnav__content">
      <ul class="globalnav__links">
        <li><a href="{% if page.url == rootUrl %}#{% else %}{{ rootUrl }}{% endif %}">{% if isEn %}Home{% else %}Start{% endif %}</a></li>
        <li><a href="{{ navPrefix }}#experience">{% if isEn %}Experience{% else %}Erfahrung{% endif %}</a></li>
        <li><a href="{{ navPrefix }}#education">{% if isEn %}Education{% else %}Bildung{% endif %}</a></li>
        <li><a href="{{ navPrefix }}#certifications">{% if isEn %}Certificates{% else %}Zertifikate{% endif %}</a></li>
        <li><a href="{{ navPrefix }}#abroad">{% if isEn %}Abroad{% else %}Ausland{% endif %}</a></li>
        <li><a href="{{ navPrefix }}#languages">{% if isEn %}Languages{% else %}Sprachen{% endif %}</a></li>
        <li><a href="{{ projectsUrl }}">{% if isEn %}Projects{% else %}Projekte{% endif %}</a></li>
      </ul>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer class="page-footer">
    <a href="{{ impressumUrl }}">{% if isEn %}Legal Notice{% else %}Impressum{% endif %}</a>
    <span aria-hidden="true">·</span>
    <a href="{{ datenschutzUrl }}">{% if isEn %}Privacy Policy{% else %}Datenschutz{% endif %}</a>
  </footer>

  <button class="back-to-top" type="button" aria-label="{% if isEn %}Back to top{% else %}Zum Seitenanfang{% endif %}">
    <i class="bi bi-arrow-up" aria-hidden="true"></i>
  </button>

  <script>
    (function () {
      const btn = document.querySelector('.back-to-top');
      if (!btn) return;

      const toggle = () => {
        if (window.scrollY > 300) {
          btn.classList.add('back-to-top--visible');
        } else {
          btn.classList.remove('back-to-top--visible');
        }
      };

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
    })();
  </script>
</body>
</html>
