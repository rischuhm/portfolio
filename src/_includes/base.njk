<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>{% if title %}{{ title }} — {{ cv.name }}{% else %}{{ cv.name }} — {{ cv.title }}{% endif %}</title>
  <meta name="description" content="{{ cv.summary }}">
  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="{{ '/styles/bootstrap-icons/bootstrap-icons.css' | url }}">
  <link rel="stylesheet" href="{{ '/styles/main.css' | url }}">
</head>
<body>
  {% set navPrefix = "" if page.url == "/" else ("/" | url) %}
  <nav class="globalnav" aria-label="Global">
    <div class="globalnav__content">
      <ul class="globalnav__links">
        <li><a href="{% if page.url == '/' %}#{% else %}{{ '/' | url }}{% endif %}">Start</a></li>
        <li><a href="{{ navPrefix }}#experience">Erfahrung</a></li>
        <li><a href="{{ navPrefix }}#education">Bildung</a></li>
        <li><a href="{{ navPrefix }}#certifications">Zertifikate</a></li>
        <li><a href="{{ navPrefix }}#abroad">Ausland</a></li>
        <li><a href="{{ navPrefix }}#languages">Sprachen</a></li>
        <li><a href="{{ '/projects/' | url }}">Projekte</a></li>
      </ul>
    </div>
  </nav>

  {{ content | safe }}

  <footer class="page-footer">
    <a href="{{ '/impressum/' | url }}">Impressum</a>
    <span aria-hidden="true">·</span>
    <a href="{{ '/datenschutz/' | url }}">Datenschutz</a>
  </footer>

  <button class="back-to-top" type="button" aria-label="Zum Seitenanfang">
    <i class="bi bi-arrow-up" aria-hidden="true"></i>
  </button>

  <script>
    (function () {
      const btn = document.querySelector('.back-to-top');
      if (!btn) return;

      const toggle = () => {
        if (window.scrollY > 300) {
          btn.classList.add('back-to-top--visible');
        } else {
          btn.classList.remove('back-to-top--visible');
        }
      };

      btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
    })();
  </script>
</body>
</html>
